# Your Neon / Supabase / any Postgres connection string
# This is the ONLY secret you manage — users supply their own DB URL via the app
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# The public URL of this deployed server (set automatically on Railway)
# Used so the app can verify it's talking to the right backend
BACKEND_URL=https://your-app.railway.app

PORT=3000
